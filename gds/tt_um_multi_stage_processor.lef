VERSION 5.8 ;
BUSBITCHARS "[]" ;
DIVIDERCHAR "/" ;

MACRO tt_um_multi_stage_processor
  CLASS BLOCK ;
  ORIGIN 0 0 ;
  SIZE 167 BY 108 ;

  # Power pins
  PIN VPWR
    DIRECTION INOUT ;
    USE POWER ;
    PORT
      LAYER met1 ;
      RECT 0 103 167 108 ;
    END
  END VPWR

  PIN VGND
    DIRECTION INOUT ;
    USE GROUND ;
    PORT
      LAYER met1 ;
      RECT 0 0 167 5 ;
    END
  END VGND

  # ui_in[7:0]
  PIN ui_in[0]
    DIRECTION INPUT ;
    PORT
      LAYER met2 ;
      RECT 5 10 7 12 ;
    END
  END ui_in[0]

  PIN ui_in[1]
    DIRECTION INPUT ;
    PORT
      LAYER met2 ;
      RECT 10 10 12 12 ;
    END
  END ui_in[1]

  PIN ui_in[2]
    DIRECTION INPUT ;
    PORT
      LAYER met2 ;
      RECT 15 10 17 12 ;
    END
  END ui_in[2]

  PIN ui_in[3]
    DIRECTION INPUT ;
    PORT
      LAYER met2 ;
      RECT 20 10 22 12 ;
    END
  END ui_in[3]

  PIN ui_in[4]
    DIRECTION INPUT ;
    PORT
      LAYER met2 ;
      RECT 25 10 27 12 ;
    END
  END ui_in[4]

  PIN ui_in[5]
    DIRECTION INPUT ;
    PORT
      LAYER met2 ;
      RECT 30 10 32 12 ;
    END
  END ui_in[5]

  PIN ui_in[6]
    DIRECTION INPUT ;
    PORT
      LAYER met2 ;
      RECT 35 10 37 12 ;
    END
  END ui_in[6]

  PIN ui_in[7]
    DIRECTION INPUT ;
    PORT
      LAYER met2 ;
      RECT 40 10 42 12 ;
    END
  END ui_in[7]

  # uo_out[7:0]
  PIN uo_out[0]
    DIRECTION OUTPUT ;
    PORT
      LAYER met2 ;
      RECT 5 90 7 92 ;
    END
  END uo_out[0]

  PIN uo_out[1]
    DIRECTION OUTPUT ;
    PORT
      LAYER met2 ;
      RECT 10 90 12 92 ;
    END
  END uo_out[1]

  PIN uo_out[2]
    DIRECTION OUTPUT ;
    PORT
      LAYER met2 ;
      RECT 15 90 17 92 ;
    END
  END uo_out[2]

  PIN uo_out[3]
    DIRECTION OUTPUT ;
    PORT
      LAYER met2 ;
      RECT 20 90 22 92 ;
    END
  END uo_out[3]

  PIN uo_out[4]
    DIRECTION OUTPUT ;
    PORT
      LAYER met2 ;
      RECT 25 90 27 92 ;
    END
  END uo_out[4]

  PIN uo_out[5]
    DIRECTION OUTPUT ;
    PORT
      LAYER met2 ;
      RECT 30 90 32 92 ;
    END
  END uo_out[5]

  PIN uo_out[6]
    DIRECTION OUTPUT ;
    PORT
      LAYER met2 ;
      RECT 35 90 37 92 ;
    END
  END uo_out[6]

  PIN uo_out[7]
    DIRECTION OUTPUT ;
    PORT
      LAYER met2 ;
      RECT 40 90 42 92 ;
    END
  END uo_out[7]

END tt_um_multi_stage_processor

END LIBRARY

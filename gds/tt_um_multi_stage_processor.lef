VERSION 5.8 ;
BUSBITCHARS "<>" ;
DIVIDERCHAR "/" ;
MACRO tt_um_multi_stage_processor
  CLASS BLOCK ;
  ORIGIN 0.000 0.000 ;
  SIZE 161.000 BY 225.760 ;

  # Power rails — full width at top and bottom
  PIN VPWR
    DIRECTION INOUT ;
    USE POWER ;
    PORT
      LAYER met1 ;
      RECT 0.000 220.760 161.000 225.760 ;
    END
  END VPWR

  PIN VGND
    DIRECTION INOUT ;
    USE GROUND ;
    PORT
      LAYER met1 ;
      RECT 0.000 0.000 161.000 5.000 ;
    END
  END VGND

  # ======================
  # ui[7:0] — bottom edge
  # ======================
  PIN ui[0]
    DIRECTION INPUT ;
    PORT
      LAYER met2 ; RECT 5.000 10.000 7.000 12.000 ;
    END
  END ui[0]
  PIN ui[1]
    DIRECTION INPUT ;
    PORT
      LAYER met2 ; RECT 10.000 10.000 12.000 12.000 ;
    END
  END ui[1]
  PIN ui[2]
    DIRECTION INPUT ;
    PORT
      LAYER met2 ; RECT 15.000 10.000 17.000 12.000 ;
    END
  END ui[2]
  PIN ui[3]
    DIRECTION INPUT ;
    PORT
      LAYER met2 ; RECT 20.000 10.000 22.000 12.000 ;
    END
  END ui[3]
  PIN ui[4]
    DIRECTION INPUT ;
    PORT
      LAYER met2 ; RECT 25.000 10.000 27.000 12.000 ;
    END
  END ui[4]
  PIN ui[5]
    DIRECTION INPUT ;
    PORT
      LAYER met2 ; RECT 30.000 10.000 32.000 12.000 ;
    END
  END ui[5]
  PIN ui[6]
    DIRECTION INPUT ;
    PORT
      LAYER met2 ; RECT 35.000 10.000 37.000 12.000 ;
    END
  END ui[6]
  PIN ui[7]
    DIRECTION INPUT ;
    PORT
      LAYER met2 ; RECT 40.000 10.000 42.000 12.000 ;
    END
  END ui[7]

  # ======================
  # uo[7:0] — top edge
  # ======================
  PIN uo[0]
    DIRECTION OUTPUT ;
    PORT
      LAYER met2 ; RECT 5.000 213.760 7.000 215.760 ;
    END
  END uo[0]
  PIN uo[1]
    DIRECTION OUTPUT ;
    PORT
      LAYER met2 ; RECT 10.000 213.760 12.000 215.760 ;
    END
  END uo[1]
  PIN uo[2]
    DIRECTION OUTPUT ;
    PORT
      LAYER met2 ; RECT 15.000 213.760 17.000 215.760 ;
    END
  END uo[2]
  PIN uo[3]
    DIRECTION OUTPUT ;
    PORT
      LAYER met2 ; RECT 20.000 213.760 22.000 215.760 ;
    END
  END uo[3]
  PIN uo[4]
    DIRECTION OUTPUT ;
    PORT
      LAYER met2 ; RECT 25.000 213.760 27.000 215.760 ;
    END
  END uo[4]
  PIN uo[5]
    DIRECTION OUTPUT ;
    PORT
      LAYER met2 ; RECT 30.000 213.760 32.000 215.760 ;
    END
  END uo[5]
  PIN uo[6]
    DIRECTION OUTPUT ;
    PORT
      LAYER met2 ; RECT 35.000 213.760 37.000 215.760 ;
    END
  END uo[6]
  PIN uo[7]
    DIRECTION OUTPUT ;
    PORT
      LAYER met2 ; RECT 40.000 213.760 42.000 215.760 ;
    END
  END uo[7]

  # ======================
  # uio[7:0] — middle
  # ======================
  PIN uio[0]
    DIRECTION INOUT ;
    PORT
      LAYER met2 ; RECT 5.000 111.880 7.000 113.880 ;
    END
  END uio[0]
  PIN uio[1]
    DIRECTION INOUT ;
    PORT
      LAYER met2 ; RECT 10.000 111.880 12.000 113.880 ;
    END
  END uio[1]
  PIN uio[2]
    DIRECTION INOUT ;
    PORT
      LAYER met2 ; RECT 15.000 111.880 17.000 113.880 ;
    END
  END uio[2]
  PIN uio[3]
    DIRECTION INOUT ;
    PORT
      LAYER met2 ; RECT 20.000 111.880 22.000 113.880 ;
    END
  END uio[3]
  PIN uio[4]
    DIRECTION INOUT ;
    PORT
      LAYER met2 ; RECT 25.000 111.880 27.000 113.880 ;
    END
  END uio[4]
  PIN uio[5]
    DIRECTION INOUT ;
    PORT
      LAYER met2 ; RECT 30.000 111.880 32.000 113.880 ;
    END
  END uio[5]
  PIN uio[6]
    DIRECTION INOUT ;
    PORT
      LAYER met2 ; RECT 35.000 111.880 37.000 113.880 ;
    END
  END uio[6]
  PIN uio[7]
    DIRECTION INOUT ;
    PORT
      LAYER met2 ; RECT 40.000 111.880 42.000 113.880 ;
    END
  END uio[7]

END tt_um_multi_stage_processor
END LIBRARY
